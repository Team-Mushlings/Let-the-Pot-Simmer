coins = 25
inventory = {}

def check_special_recipe(ingredients):
    ingredient_set = set(ingredients)

    for recipe_ingredients, name, score in SPECIAL_RECIPES:
        if recipe_ingredients.issubset(ingredient_set):
            return {
                "name": name,
                "score": score,
                "special": True
            }

    return None


def generate_soup_name(ingredients):
    trait_counts = {}
    trait_order = []

    for ingredient in ingredients:
        trait = TRAITS[ingredient]

        if trait not in trait_counts:
            trait_counts[trait] = 0
            trait_order.append(trait)

        trait_counts[trait] += 1

    repeated_traits = [
        trait for trait in trait_order
        if trait_counts[trait] >= 2
    ]

    other_traits = [
        trait for trait in trait_order
        if trait_counts[trait] < 2
    ]

    selected_traits = (repeated_traits + other_traits)[:3]

    return " ".join(selected_traits) + " Soup"


def calculate_score(ingredients):
    trait_counts = {}

    for ingredient in ingredients:
        trait = TRAITS[ingredient]
        trait_counts[trait] = trait_counts.get(trait, 0) + 1

    unique_traits = len(trait_counts)

    repeated_bonus_ingredients = sum(
        count
        for count in trait_counts.values()
        if count >= 2
    )

    score = 10
    score += unique_traits * 10
    score += repeated_bonus_ingredients * 5

    return score


def make_soup(ingredients):
    special = check_special_recipe(ingredients)

    if special:
        return special

    return {
        "name": generate_soup_name(ingredients),
        "score": calculate_score(ingredients),
        "special": False
    }
orders_completed = 0


recipe_book = {
    "Wild Soup": False,
