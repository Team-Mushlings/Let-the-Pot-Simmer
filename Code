}

def shop():
    global coins

    while True:

        print("\n=== Shop ===")
        print("Coins:", coins)

        for ingredient, price in SHOP.items():
            print("- " + ingredient + " (" + str(price) + " coins)")

        print("\nType 'exit' to leave the shop.")

        choice = input("\nBuy what? ").strip().lower()

        if choice == "exit":
            break

        if choice not in SHOP:
            print("Item not found.")
            continue

        cost = SHOP[choice]

        if coins < cost:
            print("Not enough coins!")
            continue

        coins -= cost
        if choice not in inventory:
            inventory[choice] = 0

        inventory[choice] += 1

        print("Bought " + choice + "!")
        print("Coins left:", coins)



